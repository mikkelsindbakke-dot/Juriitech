# ======================================================================
# KRITISK: Filer der ALDRIG må uploades til GitHub
# ======================================================================

# API-nøgler og hemmeligheder
.env
.env.*
!.env.example
.streamlit/secrets.toml

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE-filer
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Streamlit-cache
.streamlit/cache/

# Tester / outputs
*.docx.tmp
/tmp/

# Uploads-mappe (brugerdata hører ikke i Git)
uploads/
output/

# Eval-cases indeholder klage-tekst + præcedens-citationer trukket fra
# en specifik tenant's analyse_arkiv. Det er privat klient-data og må
# ALDRIG committes. Kun cases.example.json (placeholder-template)
# er versioneret. Hver tenant/udvikler skal kopiere example til en
# privat cases.json eller cases-<tenant>.json lokalt.
eval/cases.json
eval/cases-*.json
eval/results-*.json

# Backup-filer
*.bak
*.backup
*~

# Database-backups indeholder persondata — må ALDRIG i git
backups/
*.sql.gz
*.dump

# E2E-test artefakter — fixture-PDF'er og screenshots genereres lokalt
# pr. kørsel. Selve test-koden er versioneret, men output ikke.
tests/e2e/fixtures/*.pdf
tests/e2e/screenshots/
tests/e2e/reports/

# Python distribution
*.egg-info/
build/
dist/

# Git worktrees (skill superpowers:using-git-worktrees opretter dem her)
.worktrees/
